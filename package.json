{
  "name": "tmux-web",
  "version": "1.7.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Browser-based tmux frontend with multiple terminal backends",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "bun run bun-build.ts --watch & bun run --watch src/server/index.ts",
    "build": "bun run bun-build.ts",
    "test": "bun test && bunx playwright test",
    "test:unit": "bun test",
    "test:e2e": "bunx playwright test",
    "coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "coverage:check": "bun test --coverage --coverage-reporter=lcov && bun run scripts/check-coverage.ts",
    "start": "bun src/server/index.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-fonts": "^0.1.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "fast-check": "^4.7.0",
    "jsdom": "^29.0.2",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3"
  }
}
