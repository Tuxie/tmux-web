{
  "name": "tmux-web",
  "version": "1.4.2",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Browser-based tmux frontend with multiple terminal backends",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "bun run bun-build.ts --watch & bun run --watch src/server/index.ts",
    "build": "bun run bun-build.ts",
    "test": "bun test && node node_modules/.bin/playwright test",
    "test:unit": "bun test",
    "test:e2e": "node node_modules/.bin/playwright test",
    "start": "bun src/server/index.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-fonts": "^0.1.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0"
  }
}
