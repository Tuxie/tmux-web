{
  "name": "tmux-web",
  "version": "1.8.1",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Browser-based tmux frontend with multiple terminal backends",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "bun run bun-build.ts --watch & bun run --watch src/server/index.ts",
    "build": "bun run bun-build.ts",
    "test": "bun test && bunx playwright test",
    "test:unit": "bun test",
    "test:e2e": "bunx playwright test",
    "coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "coverage:check": "bun test --coverage --coverage-reporter=lcov && bun run scripts/check-coverage.ts",
    "start": "bun src/server/index.ts",
    "desktop:dev": "bun run bun-build.ts && make tmux-web && TMUX_TERM_TMUX_WEB=./tmux-web electrobun dev",
    "desktop:build": "electrobun build",
    "desktop:stable": "bun run bun-build.ts && make tmux-web && electrobun build --env=stable"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "electrobun": "1.16.0",
    "fast-check": "^4.7.0",
    "jsdom": "^29.0.2",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3"
  }
}
