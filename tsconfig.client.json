{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "outDir": "dist/client",
    "rootDir": "src"
  },
  "include": ["src/client/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
