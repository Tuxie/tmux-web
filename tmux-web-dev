#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

MARKER="dist/client/xterm.js"
SERVER_PID=""

cleanup() {
  if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
    kill "$SERVER_PID"
    wait "$SERVER_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT
trap 'cleanup; exit 0' INT TERM

rebuild_if_needed() {
  if [ ! -f "$MARKER" ] || \
     find src/client src/shared bun-build.ts -newer "$MARKER" | grep -q .; then
    echo "[tmux-web-dev] rebuilding client..." >&2
    bun run bun-build.ts
  fi
  local assets="src/server/assets-embedded.ts"
  if [ ! -f "$assets" ] || \
     find dist/client tmux.conf scripts/generate-assets.ts -newer "$assets" | grep -q .; then
    bun run scripts/generate-assets.ts
  fi
}

start_server() {
  rebuild_if_needed
  bun src/server/index.ts "$@" &
  SERVER_PID=$!
}

wait_for_head_change() {
  local last_head new_head
  last_head=$(git rev-parse HEAD || echo HEAD)

  if command -v inotifywait >/dev/null 2>&1; then
    while IFS= read -r _; do
      new_head=$(git rev-parse HEAD 2>/dev/null) || continue
      [ "$new_head" != "$last_head" ] && return 0
    done < <(inotifywait -qmr -e close_write,moved_to .git/ 2>/dev/null)
  else
    while sleep 2; do
      new_head=$(git rev-parse HEAD 2>/dev/null) || continue
      [ "$new_head" != "$last_head" ] && return 0
    done
  fi
}

start_server "$@"

# If server exited immediately (e.g. --help or config error), just exit
sleep 0.2
if ! kill -0 "$SERVER_PID" 2>/dev/null; then
  wait "$SERVER_PID" 2>/dev/null || exit $?
  exit 0
fi

while true; do
  wait_for_head_change
  echo "[tmux-web-dev] restarting after commit..." >&2
  if kill -0 "$SERVER_PID" 2>/dev/null; then
    kill "$SERVER_PID"
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  start_server "$@"
done
